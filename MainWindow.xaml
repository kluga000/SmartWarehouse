<Window x:Class="SmartWarehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartWarehouse"
        mc:Ignorable="d"
        Title="SmartWarehouse" Height="500" Width="900" Background="#F0F2F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Пошук товару:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox x:Name="txtSearch" Width="250" VerticalAlignment="Center" Padding="5"/>
            <Button Content="Знайти" Margin="10,0,0,0" Width="100" Padding="5" Click="btnSearch_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" SelectionMode="Single" 
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DDDDDD"
                  RowHeight="30" AlternatingRowBackground="#FAFAFA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="2*"/>

                <DataGridTextColumn Header="Категорія" Binding="{Binding Category.Name}" Width="1.5*"/>

                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                <DataGridTextColumn Header="Ціна (грн)" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="100"/>
                <DataGridTextColumn Header="Кількість" Binding="{Binding Quantity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,15,0,0" HorizontalAlignment="Right">
            <Button Content="Додати товар" Margin="5,0" Padding="15,7" Background="#E1E1E1"/>
            <Button Content="Видалити" Margin="5,0" Padding="15,7" Background="#FFE1E1"/>
            <Button x:Name="btnReport" Content="Звіт по складу" Margin="15,0,0,0" 
                    Padding="20,7" FontWeight="Bold" Background="#D1E7DD"
                    Click="btnReport_Click"/>
        </StackPanel>
    </Grid>
</Window>