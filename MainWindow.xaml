<Window x:Class="SmartWarehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartWarehouse" Height="650" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Пошук товару:" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearch" Width="400" Height="35" VerticalContentAlignment="Center"/>
            <Button Content="Знайти" Click="btnSearch_Click" Margin="10,0,0,0" Width="100"/>
        </StackPanel>

        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" FontSize="14">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                            <Setter Property="Foreground" Value="#A0A0A0"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category.FullName}" Width="200"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120"/>
                <DataGridTextColumn Header="Ціна (грн)" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="120"/>
                <DataGridTextColumn Header="Кількість" Binding="{Binding Quantity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" Padding="15,10" Margin="0,15,0,0" BorderBrush="#DEE2E6" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Змінити кількість вибраного товару:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
                <TextBox x:Name="txtAmountChange" Width="80" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0" Text="1"/>
                <Button Content="➕ Додати" Click="btnIncrease_Click" Width="90" Height="30" Background="#D1E7DD" Margin="0,0,5,0"/>
                <Button Content="➖ Списати" Click="btnDecrease_Click" Width="90" Height="30" Background="#F8D7DA"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,20,0,0" HorizontalAlignment="Right">
            <Button Content="Додати новий" Click="btnAddProduct_Click" Padding="20,10" Margin="0,0,10,0"/>
            <Button Content="Видалити" Click="btnDelete_Click" Padding="20,10" Background="#FFE1E1"/>
            <Button Content="Звіт по складу" Click="btnReport_Click" Padding="25,10" Background="#D1E7DD" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>