<Window x:Class="SmartWarehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartWarehouse — Система управління складом" Height="650" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Пошук товару:" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearch" Width="400" Height="35" VerticalContentAlignment="Center"/>
            <Button Content="Знайти" Click="btnSearch_Click" Margin="10,0,0,0" Width="100"/>
        </StackPanel>

        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" FontSize="14" SelectionMode="Single"
                  SelectionChanged="dgProducts_SelectionChanged">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                            <Setter Property="Foreground" Value="#A0A0A0"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Quantity}" Value="0"/>
                                <Condition Binding="{Binding IsDeleted}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" CanUserSort="False"/>
                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*" CanUserSort="False"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category.Name}" Width="180" CanUserSort="False">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding Category.FullName}" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Margin" Value="5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120" CanUserSort="False"/>
                <DataGridTextColumn Header="Ціна (грн)" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="120" CanUserSort="False"/>
                <DataGridTextColumn Header="Кількість" Binding="{Binding Quantity}" Width="100" CanUserSort="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" Padding="15,10" Margin="0,15,0,0" BorderBrush="#DEE2E6" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Змінити кількість вибраного товару:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
                <TextBox x:Name="txtAmountChange" Width="80" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0" Text="1"/>
                <Button Content="➕ Додати" Click="btnIncrease_Click" Width="90" Height="30" Background="#D1E7DD" Margin="0,0,5,0"/>
                <Button Content="➖ Списати" Click="btnDecrease_Click" Width="90" Height="30" Background="#F8D7DA"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,20,0,0" HorizontalAlignment="Right">
            <Button Content="Додати новий" Click="btnAddProduct_Click" Padding="20,10" Margin="0,0,10,0"/>
            <Button x:Name="btnDelete" Content="Відновити/Видалити" Click="btnDelete_Click" Padding="20,10" Background="#FFE1E1"/>
            <Button x:Name="btnReport" Content="Звіт по складу" Click="btnReport_Click" Padding="25,10" Background="#D1E7DD" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>