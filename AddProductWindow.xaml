<Window x:Class="SmartWarehouse.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додавання товару" Height="450" Width="350" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Категорія:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="cbCategories" IsEditable="True" Margin="0,0,0,15" Height="30" 
                      DisplayMemberPath="FullName"/>

            <TextBlock Text="Назва товару:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtName" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>

            <TextBlock Text="Артикул:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtArticle" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>

            <TextBlock Text="Ціна:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtPrice" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>

            <TextBlock Text="Кількість:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="txtQuantity" Margin="0,0,0,15" Height="30" VerticalContentAlignment="Center"/>

            <Button Content="Зберегти товар" Click="btnSave_Click" 
                    Height="40" Background="#D1E7DD" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>